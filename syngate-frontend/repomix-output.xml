                <dd className="text-sm font-mono text-foreground">
                  {usuario.cartaoId ? (
                    <span className="bg-muted px-2 py-0.5 rounded text-xs">{usuario.cartaoId}</span>
                  ) : (
                    <span className="text-muted-foreground">Nenhum cartão vinculado</span>
                  )}
